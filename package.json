  "dependencies": {
    "@discord/embedded-app-sdk": "^1.1.2",
    "express": "^4.19.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "vite": "^5.3.3"
  }
}
