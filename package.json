{
  "name": "black-smith-uncle",
  "version": "1.0.0",
  "description": "ブラック刀鍛冶おじさん 〜聖剣農場〜",
  "main": "server.js",
  "scripts": {
    "dev:server": "nodemon server.js",
    "dev:client": "vite client",
